# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Polymarket CLOB API credentials
# Obtain by running: python -m polymarket.auth setup
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Your Polygon wallet private key (0x-prefixed)
POLYMARKET_PRIVATE_KEY=0x...

# Polygon chain (137 = mainnet, 80002 = Amoy testnet)
POLYMARKET_CHAIN_ID=137

# Trading parameters (safe defaults — adjust carefully)
MAX_POSITION_USDC=50.0
MAX_CONCURRENT_POSITIONS=5
MIN_EDGE_THRESHOLD=0.05
MIN_CONFIDENCE_THRESHOLD=0.6
KELLY_FRACTION=0.25
STOP_LOSS_PCT=0.30
TAKE_PROFIT_PCT=0.80
SCAN_INTERVAL_MINUTES=15

# Set to "true" to run without placing real orders
DRY_RUN=false
