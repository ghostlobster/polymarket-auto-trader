# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Polymarket CLOB API credentials
# Obtain by running: python -m polymarket.auth setup
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Your Polygon wallet private key (0x-prefixed)
POLYMARKET_PRIVATE_KEY=0x...

# Polygon chain (137 = mainnet, 80002 = Amoy testnet)
POLYMARKET_CHAIN_ID=137

# Trading parameters (safe defaults — adjust carefully)
MAX_POSITION_USDC=50.0
MAX_CONCURRENT_POSITIONS=5
MIN_EDGE_THRESHOLD=0.05
MIN_CONFIDENCE_THRESHOLD=0.6
KELLY_FRACTION=0.25
STOP_LOSS_PCT=0.30
TAKE_PROFIT_PCT=0.80
SCAN_INTERVAL_MINUTES=15

# Set to "true" to run without placing real orders
DRY_RUN=false

# --- Cognitive-arbitrage engine ---
# strict — Polymarket + DuckDuckGo only (no external API calls)
# hybrid — sensible defaults: news on, manifold + metaculus on, polling off
# full   — every adapter on (subject to its own flag below)
EDGE_MODE=hybrid

# Per-source feature flags — each overrides the mode default when set true.
NEWSAPI_ENABLED=false
NEWSAPI_KEY=
GDELT_ENABLED=false
MANIFOLD_ENABLED=false
KALSHI_ENABLED=false
METACULUS_ENABLED=false
POLLING_AGGREGATOR_ENABLED=false

# Calibration / risk hardening
CALIBRATION_INTERVAL_SECS=3600
CALIBRATION_MIN_RESOLUTIONS_FOR_SHRINKAGE=20
RISK_CLUSTER_CAP_FRAC=0.30
RISK_CATEGORY_CAP_FRAC=0.40
RISK_RESOLUTION_WINDOW_CAP_FRAC=0.20
RISK_PER_TRADE_CAP_FRAC=0.10
RISK_MIN_TRADE_USDC=5.0
RISK_SHRINKAGE_FLOOR=0.25

# Order-book snapshotter cadence
SNAPSHOT_INTERVAL_SECS=300
SNAPSHOT_MARKET_LIMIT=40

# Theta gating in portfolio monitor
THETA_TAKE_PROFIT_PCT=0.40
THETA_WINDOW_HOURS=24.0
THETA_FORCE_CLOSE_HOURS=2.0

# Thesis fill slippage budget
THESIS_MAX_SLIPPAGE=0.02
THESIS_POSTFILL_DRIFT_TRACK_MIN=120

# Ensemble signal generator
ENSEMBLE_ENABLED=true
ENSEMBLE_WEIGHT_PRIOR=0.25
ENSEMBLE_WEIGHT_BULL=0.25
ENSEMBLE_WEIGHT_BEAR=0.25
ENSEMBLE_WEIGHT_MARKET=0.25
ENSEMBLE_DISAGREEMENT_FLOOR=0.05

# --- Copy-trading subsystem ---
# Master switch
COPY_ENABLED=false

# Default preset for newly-tracked traders: mirror | scaled_market | scaled_limit | conservative | shadow
COPY_DEFAULT_PRESET=scaled_market

# How often the copy loop polls leader wallets for new trades
COPY_POLL_SECONDS=30

# How often the audit loop reconciles expected copies vs actual orders
COPY_AUDIT_INTERVAL_SECS=60
COPY_AUDIT_WINDOW_SECS=120

# Promotion gate: min paper-mode confirmed trades before live becomes eligible
COPY_MIN_CONFIRMED_PAPER_TRADES=20

# Auto-demote a trader if audit miss rate exceeds this in the rolling window
COPY_AUDIT_MISS_RATE_DEMOTE=0.10

# Throttle on-access performance recompute (seconds)
COPY_REPORT_REFRESH_THROTTLE_SECS=30

# Synthetic starting balance for paper accounts
COPY_PAPER_STARTING_USDC=1000.0

# Discovery
LEADERBOARD_REFRESH_HOURS=24
LEADER_MIN_TRADES=50
LEADER_MIN_WEEKS_PROFIT_FRAC=0.6
LEADER_MIN_WALLET_VOLUME=20000
LEADER_MAX_RESOLUTION_SNIPER_FRAC=0.8
LEADERBOARD_TOP_N_FOR_LLM=30
LEADERBOARD_KEEP_N=10

# Web UI for profile review
COPY_WEB_ENABLED=false
COPY_WEB_HOST=127.0.0.1
COPY_WEB_PORT=8765

# Polymarket data API (rarely needs changing)
POLYMARKET_DATA_API=https://data-api.polymarket.com
